# Copia este archivo a .env y reinicia `npm run dev` (Vite lee .env al arrancar)

# API REST — proxied por Vite (/api/v1/* → http://localhost:8080)
VITE_API_BASE_URL=/api/v1

# WebSocket — conexión DIRECTA al backend Spring Boot.
# El server Express (middleware mode) NO proxea upgrades WebSocket,
# así que socket.ts debe apuntar al backend; le añade
# /api/v1/simulations/{id}/ws por su cuenta.
VITE_WS_BASE_URL=ws://localhost:8080
